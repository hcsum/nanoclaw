#!/usr/bin/env node

import process from 'process';

function replacePrefix(value, fromPath, toPath) {
  if (!fromPath || !toPath) return value;
  if (value === fromPath) return toPath;
  if (value.startsWith(`${fromPath}/`)) {
    return `${toPath}${value.slice(fromPath.length)}`;
  }
  return value;
}

function translateArg(value) {
  let next = value;
  next = replacePrefix(
    next,
    '/workspace/group',
    process.env.NANOCLAW_HOST_GROUP_DIR,
  );
  next = replacePrefix(
    next,
    '/workspace/project',
    process.env.NANOCLAW_HOST_PROJECT_DIR,
  );
  next = replacePrefix(
    next,
    '/workspace/global',
    process.env.NANOCLAW_HOST_GLOBAL_DIR,
  );
  next = replacePrefix(next, '/workspace/ipc', process.env.NANOCLAW_HOST_IPC_DIR);
  return next;
}

async function main() {
  const url = process.env.NANOCLAW_BROWSER_PROXY_URL;
  const token = process.env.NANOCLAW_BROWSER_PROXY_TOKEN;

  if (!url || !token) {
    process.stderr.write(
      'Host browser proxy is not configured. Restart NanoClaw to enable host browser automation.\n',
    );
    process.exit(1);
  }

  const argv = process.argv.slice(2).map(translateArg);
  const cwd = process.env.NANOCLAW_HOST_GROUP_DIR;

  let response;
  try {
    response = await fetch(url, {
      method: 'POST',
      headers: {
        'content-type': 'application/json',
        'x-nanoclaw-browser-token': token,
      },
      body: JSON.stringify({ argv, cwd }),
    });
  } catch (error) {
    process.stderr.write(
      `Failed to reach host browser proxy: ${error instanceof Error ? error.message : String(error)}\n`,
    );
    process.exit(1);
  }

  let payload;
  try {
    payload = await response.json();
  } catch {
    process.stderr.write('Host browser proxy returned invalid JSON.\n');
    process.exit(1);
  }

  if (!response.ok) {
    process.stderr.write(`${payload.error || 'Host browser proxy request failed.'}\n`);
    process.exit(1);
  }

  if (payload.stdout) process.stdout.write(payload.stdout);
  if (payload.stderr) process.stderr.write(payload.stderr);
  process.exit(typeof payload.code === 'number' ? payload.code : 1);
}

main();
