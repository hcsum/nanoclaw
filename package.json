{
  "name": "nanoclaw",
  "version": "1.2.19",
  "description": "Personal Claude assistant. Lightweight, secure, customizable.",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:fix": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "prepare": "husky",
    "setup": "tsx setup/index.ts",
    "auth": "tsx src/whatsapp-auth.ts",
    "browser-use:login": "tsx src/browser-use-login.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "mac:start": "launchctl load ~/Library/LaunchAgents/com.nanoclaw.plist",
    "mac:stop": "launchctl unload ~/Library/LaunchAgents/com.nanoclaw.plist",
    "mac:restart": "launchctl kickstart -k gui/$(id -u)/com.nanoclaw",
    "log": "tail -f logs/nanoclaw.log"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.76",
    "@types/qrcode-terminal": "^0.12.0",
    "@whiskeysockets/baileys": "^7.0.0-rc.9",
    "better-sqlite3": "^11.8.1",
    "cron-parser": "^5.5.0",
    "dotenv-cli": "^11.0.0",
    "grammy": "^1.41.1",
    "link-preview-js": "^3.2.0",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "playwright": "^1.58.2",
    "proxy-agent": "^6.5.0",
    "qrcode": "^1.5.4",
    "qrcode-terminal": "^0.12.0",
    "yaml": "^2.8.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.0",
    "@vitest/coverage-v8": "^4.0.18",
    "husky": "^9.1.7",
    "prettier": "^3.8.1",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=20"
  }
}
